{
  "name": "rescuesight",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @rescuesight/web run dev",
    "dev:api": "npm --workspace @rescuesight/api run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test:api": "npm --workspace @rescuesight/api run test"
  }
}
